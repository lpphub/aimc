{
	"$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
	"files": {
		"includes": [
			"**",
			"!!**/dist",
			"!!**/node_modules",
			"!!**/public",
			"!!**/docs",
			"!!**/.claude"
		]
	},
	"overrides": [
		{
			"includes": ["**/*.{js,jsx,ts,tsx}"],
			"linter": {
				"enabled": true,
				"rules": {
					"recommended": true,
					"correctness": {
						"noUnusedVariables": "error",
						"noUnusedImports": "error"
					},
					"style": {
						"useImportType": "error",
						"noNonNullAssertion": "off"
					},
					"suspicious": {
						"noExplicitAny": "warn",
						"noDocumentCookie": "off"
					},
					"a11y": {
						"noLabelWithoutControl": "off"
					}
				}
			},
			"formatter": {
				"enabled": true,
				"indentStyle": "space",
				"indentWidth": 2,
				"lineWidth": 100
			}
		}
	],
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"jsxQuoteStyle": "single",
			"trailingCommas": "es5",
			"quoteProperties": "asNeeded",
			"semicolons": "asNeeded",
			"arrowParentheses": "asNeeded",
			"bracketSpacing": true,
			"bracketSameLine": false
		}
	},
	"css": {
		"parser": {
			"cssModules": false,
			"tailwindDirectives": true
		},
		"formatter": {
			"enabled": true
		}
	}
}
